        if (randnum <= silli_odds){
          payload = {
            bot_id: BOT_ID,
            text: response,
            attachments: [
              { type: 'reply', reply_id: body.id, base_reply_id: body.id },
            ],
          }
          await respond();
        }
      }
      else if (text.includes(' mods ban ') || (text.startsWith('mods ban ')) || (text === ('mods ban'))){
        const randnum = Math.floor(Math.random() * 100);
        if (randnum <= silli_odds){
          payload = {
            bot_id: BOT_ID,
            text: `🫡 🫡 🫡`,
            attachments: [
              { type: 'reply', reply_id: body.id, base_reply_id: body.id },
            ],
          }
          await respond();
        }
      }
