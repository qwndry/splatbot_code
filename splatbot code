            }
      
            // fallback
            if (!targetCoopNode) targetCoopNode = coopNodes[idx];
          }
      
          if (targetCoopNode && targetCoopNode.setting) {
            const setting = targetCoopNode.setting;
            const srStage = setting.coopStage?.name || "Unknown Stage";
            const kingSalmonid = setting.boss?.name || "Unknown King";
            
            // formatting weapon pool
            const weapons = setting.weapons ? setting.weapons.map(w => w.name || "Random") : [];
            const weaponPoolStr = weapons.join(', ');
      
            // timing and formatting response
            const srTimeStr = modeArg === 'current'
              ? `ends in ${getTimeDifferenceString(targetCoopNode.endTime)}`
              : `starts in ${getTimeDifferenceString(targetCoopNode.startTime)}`;
      
            messageLines.push(`SALMON RUN (Shift ${srTimeStr}):`);
            messageLines.push(`• Stage: ${srStage}`);
            messageLines.push(`• King Salmonid: ${kingSalmonid}`);
            messageLines.push(`• Weapons: ${weaponPoolStr}`);
          } else {
            messageLines.push(`[SALMON RUN]:\nData currently unavailable.`);
          }
      
          //sending final response
          payload.bot_id = BOT_ID;
          payload.text = messageLines.join('\n');
          payload.attachments = [
            { type: 'reply', reply_id: body.id, base_reply_id: body.id }
          ];
      
          await respond();
      
        } catch (error) {
          console.error("CRITICAL BOT ERROR:", error);
          try {
            payload.bot_id = BOT_ID;
            payload.text = "An error occurred while fetching the map data.";
            await respond();
          } catch (innerErr) {
            console.error("Even the error responder failed:", innerErr);
          }
        }
      } 

    return { statusCode: 200, body: 'OK' };
    }
  
    //final catch just in case an error happens anywhere above
  } catch (error) {
    console.error('Error:', error);
    return { statusCode: 500, body: 'Internal Server Error' };
  }
}
