    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  });

  console.log('GroupMe response:', await response.text());
  return { statusCode: 202, body: 'Accepted' };
}

export const handler = async (event) => {
  try {
    const body = JSON.parse(event.body || '{}');

    if (!body || !body.text) {
      return { statusCode: 400, body: 'Invalid request' };
    }

    //dont recieve messsages from bots
    if (body.sender_type === 'bot') {
      return { statusCode: 200, body: 'Ignored bot message' };
    }
    
    // check that system messages are from groupme 
    if (body.sender_type === 'system' || body.sender_id === 'system') {
      const text = body.text ? body.text.trim() : "";

      // safety-net to make sure that there actually is text there
      if (!text) return { statusCode: 200, body: 'Empty system message ignored' };
    
      let joinedName = "";
      let action = "";
    
      // (pt. 1 identifying keyword and assigning an action with some redundancies cause groupme borks sometimes)
      if (text.includes(" edited ")) {
        action = "edited";
      } else if (text.includes(" has rejoined ")) {
        action = "rejoined";
        joinedName = text.split(" has rejoined ")[0].trim();
      } else if (text.includes(" rejoined ")) { 
        action = "rejoined";
        joinedName = text.split(" rejoined ")[0].trim();
      } else if (text.includes(" has left ")) {
        action = "left";
        joinedName = text.split(" has left ")[0].trim();
      } else if (text.includes(" left ")) { 
        action = "left";
        joinedName = text.split(" left ")[0].trim();
      } else if (text.includes(" has joined ")) {
        action = "joined";
        joinedName = text.split(" has joined ")[0].trim();
      } else if (text.includes(" joined ")) { 
        action = "joined";
        joinedName = text.split(" joined ")[0].trim();
      } else if (text.includes(" was added ")) {
        action = "was added";
        joinedName = text.split(" was added ")[0].trim();
      } else if (text.includes(" admin ")) {
        action = "admin";
        // groupme is weird about admins and can do '___ was made admin' or '___ is now an admin' so thats why theres an extra text.split
        if (text.includes(" is ")) joinedName = text.split(" is ")[0].trim();
        else if (text.includes(" was ")) joinedName = text.split(" was ")[0].trim();
        else joinedName = text.split(" ")[0].trim();
      } else if (text.includes(" removed ")) {
        action = "removed";
      }
        else {
        // theres a whole lot of other system messages so this is here so bot doesn't bork
        return { statusCode: 200, body: 'Unrelated system message ignored' };
      }
    
      // (pt. 2 building the message based on action) also im not doing }
      if (action === "edited") {
        const randnum = Math.floor(Math.random() * 100);
        if (randnum <= silli_odds){
          const targetMessageId = body.source_message_id || body.id;
          payload = {
            bot_id: BOT_ID,
            text: `ᵐᶦⁿᵒʳ ˢᵖᵉˡˡᶦⁿᵍ ᵐᶦˢᵗᵃᵏᵉ`,
            attachments: [
              {
                type: "reply",
                reply_id: targetMessageId, 
                base_reply_id: targetMessageId
              }
            ]
          };
          await respond();
        }
      }
      else if (action === "rejoined") {
        payload = {
          bot_id: BOT_ID,
          text: `welcome back, ${joinedName}! you were missed!`,
          attachments: [
          ]
        };
        await respond();
      } 
      else if (action === "left") {
        payload = {
          bot_id: BOT_ID,
          text: `see ya later, ${joinedName}. hope you come back soon!`,
          attachments: [
          ]
        };
        await respond();
      } 
      else if (action === "joined" || action === "was added") {
        payload = {
          bot_id: BOT_ID,
          text: `welcome in, ${joinedName}! please read the rules and join the pool 'splatgroup'`,
          attachments: [
          ]
        };
        await respond();
      } 
      else if (action === "admin") {
        payload = {
          bot_id: BOT_ID,
          text: `congratulations ${joinedName}, you are our newest admin!`,
          attachments: [
          ]
        };
        await respond();
      }
      else if (action === "removed") {
        payload = {
          bot_id: BOT_ID,
          text: `Emergency protocols initiated. Test subject removed.`,
          attachments: [
          ]
        };
        await respond();
      }
    
      return { statusCode: 200, body: 'Handled system message' };
    }

    console.log(body.sender_id, body.name);

    //a thing for random weapon generation
    function rw2() {
      const values = Object.values(weapons);
      const randomIndex = Math.floor(Math.random() * values.length);
      const weapon = values[randomIndex];
      return weapon[0];
    }
    
    function rwByClass(cls) {
      const values = Object.values(weapons);
      const list = values.filter(w => w[3] === cls).map(w => w[0]);
      return list[Math.floor(Math.random() * list.length)];
    }
    
    function rwBySub(sub) {
      const values = Object.values(weapons);
      const list = values.filter(w => w[1] === sub).map(w => w[0]);
      return list[Math.floor(Math.random() * list.length)];
    }
    
    function rwBySpecial(special) {
      const values = Object.values(weapons);
      const list = values.filter(w => w[2] === special).map(w => w[0]);
      return list[Math.floor(Math.random() * list.length)];
    }

    function isAdmin(){
      for(var i = 0; i < adminIDS.length; i++){
        if (body.sender_id === adminIDS[i]) {
          return true;
        }
      }
      return false;
    }

    //retrieve messages
    const sensitive_text = body.text;
    const text = body.text.toLowerCase();

    //sillis
    if (!text.startsWith('!')) {
      if (text.includes('crazy')){
        const randnum = Math.floor(Math.random() * 100);
        if (randnum <= silli_odds){
          payload = {
            bot_id: BOT_ID,
            text: `crazy?`,
            attachments: [
              { type: 'reply', reply_id: body.id, base_reply_id: body.id },
            ],
          }
          await respond();
        }
      } 
      else if (silli_keywords.some(silli_keyword => text.includes(silli_keyword)) || (silli_keywords.some(silli_keyword => text.startsWith(silli_keyword)))){
        let responses = ['please censor yourself, your words are EXTREMELY harmful', 'D:', 'boo', '👎', '*sob*','BANNED','thats super scary '];
        let response = responses[Math.floor(Math.random() * responses.length)];
