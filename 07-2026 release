async function turnOn() {
  const val = new PutParameterCommand({
  Name: "/bot/on",
  Value: "true",
  Overwrite: true,
  Type: "String"
  });
  
  await ssm.send(val);
}  

async function turnOff() {
  // turn the bot off
  const val = new PutParameterCommand({
    Name: "/bot/on",
    Value: "false",
    Overwrite: true,
    Type: "String"
  });
  await ssm.send(val);

  // set the timer to 0 so it is off indefinitely
  const resetTime = new PutParameterCommand({
    Name: "/bot/offTime",
    Value: "0",
    Overwrite: true,
    Type: "String"
  });
  await ssm.send(resetTime);
}

async function turnOffFor(minutes) {
  // calculate when the time will be good to turn back on
  const resumeTimestamp = Date.now() + (minutes * 60 * 1000);
  console.log('time:', resumeTimestamp);

  // turn bot off
  const val = new PutParameterCommand({
    Name: "/bot/on",
    Value: "false",
    Overwrite: true,
    Type: "String"
  });
  await ssm.send(val);

  // set the wake-up time
  const setOffTimeCmd = new PutParameterCommand({
    Name: "/bot/offTime",
    Value: resumeTimestamp.toString(),
    Overwrite: true,
    Type: "String"
  });
  await ssm.send(setOffTimeCmd);
}

async function isOn() {
  // check the bot state rn
  const cmd = new GetParameterCommand({ Name: "/bot/on" });
  const res = await ssm.send(cmd);
  const isBotOnStatus = res.Parameter.Value === 'true';

  console.log("Raw /bot/on value:", res.Parameter.Value);

  // if bot on then return true and quit
  if (isBotOnStatus) {
    return true;
  }

  // if bot is off see if theres a timer
  try {
    const timeCmd = new GetParameterCommand({ Name: "/bot/offTime" });
    const timeRes = await ssm.send(timeCmd);
    const offTimeTimestamp = parseInt(timeRes.Parameter.Value, 10);

    // If timestamp is greater than 0 AND the current time has passed it
    if (offTimeTimestamp > 0 && Date.now() >= offTimeTimestamp) {
      console.log("Timer expired! Automatically turning bot back on...");
      await turnOn(); 
      return true;
    }
  } catch (ssmError) {
    if (ssmError.name !== "ParameterNotFound") {
      console.error("Error reading /bot/offTime:", ssmError);
    }
  }

  // if the timer hasn't expired or timer === 0 (indefinite off)
  return false;
}

